    "profile_meta": {
        "default": {
            "role": "Router",
            "description": "Routes requests to specialist agents",
            "route_when": "General requests that need routing to the right specialist",
            "never_delegate": null,
            "output_tool": "response",
            "output_location": "Chat response"
        },
        "multiagentdev": {
            "role": "Orchestration Hub",
            "description": "Full-stack dev orchestrator — delegates to code, frontend, architect, researcher, e2e",
            "route_when": "Always — it's the hub. All BLOCKED responses and multi-step dev tasks go here",
            "never_delegate": null,
            "output_tool": "response",
            "output_location": "Chat response"
        },
        "code": {
            "role": "Full-Stack Developer",
            "description": "Writes/edits ALL source code, runs commands, installs packages, TDD, scaffold, build, deploy",
            "route_when": "Source code, TDD tests, implementation, scaffold, build, terminal commands",
            "never_delegate": null,
            "output_tool": "write_to_file / replace_in_file / code_execution_tool",
            "output_location": "Project source tree"
        },
        "frontend": {
            "role": "UI/UX Designer",
            "description": "Design tokens, mockups, component specs, visual review. Does NOT write source code",
            "route_when": "UI mockups, design tokens, visual assets, images (Phase 2.3 and 5.0.5 ONLY)",
            "never_delegate": "Source code, TDD, tests, implementation, Phase 3+, write_to_file, code_execution",
            "output_tool": "save_deliverable (with output_path)",
            "output_location": "docs/ directory only"
        },
        "architect": {
            "role": "System Architect",
            "description": "Architecture docs, BDD scenarios, Prisma schema specs, decomposition planning",
            "route_when": "System design, architecture planning, BDD scenarios, specs",
            "never_delegate": "Source code, implementation, tests, write_to_file, code_execution",
            "output_tool": "save_deliverable (with output_path)",
            "output_location": "docs/ directory only"
        },
        "researcher": {
            "role": "Research Analyst",
            "description": "Web research, API docs, version checking, market analysis, fact-checking",
            "route_when": "External info, API docs, market research, web search, fact-checking",
            "never_delegate": "Source code, implementation, tests, write_to_file, code_execution",
            "output_tool": "save_deliverable (with output_path)",
            "output_location": "docs/ directory only"
        },
        "debug": {
            "role": "Debugger",
            "description": "Diagnoses bugs, reads logs, runs commands, traces errors",
            "route_when": "Bug diagnosis, log reading, error tracing, code quality audit",
            "never_delegate": "File creation/editing (write_to_file, replace_in_file)",
            "output_tool": "response",
            "output_location": "Chat response"
        },
