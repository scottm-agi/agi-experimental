# =============================================================================
# AGIX Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values
# 
# PRODUCTION SETUP:
#   1. Copy this file: cp .env.example .env
#   2. Set AUTH_LOGIN and AUTH_PASSWORD (REQUIRED for production)
#   3. Generate FLASK_SECRET_KEY: python -c "import secrets; print(secrets.token_hex(32))"
#   4. Add your API keys for LLM providers
#   5. Configure domain and Railway-specific settings
# =============================================================================

# Environment and Mode
AGIX_DEV_MODE=true
AGIX_ENV=development

# =============================================================================
# AUTHENTICATION (REQUIRED IN PRODUCTION)
# =============================================================================
# Default credentials - CHANGE THESE IN PRODUCTION!
AUTH_LOGIN=admin
AUTH_PASSWORD=changeme_in_production

# RFC (Remote Function Call) password for container-to-container communication
RFC_PASSWORD=your_rfc_password_here

# =============================================================================
# SECURITY KEYS
# =============================================================================
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=

# Root password for container access (if needed)
ROOT_PASSWORD=your_root_password_here

# =============================================================================
# DOMAIN & NETWORK (for Production/Railway)
# =============================================================================
# Your production domain (e.g., agix.example.com or Railway auto-generated)
DOMAIN=localhost

# CORS allowed origins (comma-separated for multiple)
ALLOWED_ORIGINS=https://localhost,https://localhost:8443,http://127.0.0.1:8880,http://localhost:8880

# ACME email for Let's Encrypt certificate notifications
ACME_EMAIL=admin@localhost

# =============================================================================
# REDIS CONFIGURATION
# =============================================================================
REDIS_HOST=redis
REDIS_PORT=6379
# Set a password for Redis in production
REDIS_PASSWORD=

# =============================================================================
# RUNTIME SETTINGS
# =============================================================================
AGIX_PERSISTENT_RUNTIME_ID=your_runtime_id_here

# Timezone settings
DEFAULT_USER_UTC_OFFSET_MINUTES=-420
DEFAULT_USER_TIMEZONE=America/Denver

# Resource limits (for docker-compose)
MEMORY_LIMIT=4G
MEMORY_RESERVATION=1G

# =============================================================================
# SUPERVISOR SETTINGS
# =============================================================================
SUPERVISOR_ENABLED=true
LLM_SUPERVISOR_ENABLED=true

# =============================================================================
# TELEMETRY
# =============================================================================
ANONYMIZED_TELEMETRY=false

# =============================================================================
# LLM API KEYS
# =============================================================================
# OpenAI
API_KEY_OPENAI=

# Anthropic (Claude)
API_KEY_ANTHROPIC=

# Google (Gemini)
API_KEY_GOOGLE=

# Azure OpenAI
API_KEY_AZURE=

# OpenRouter
API_KEY_OPENROUTER=
OPENROUTER=

# DeepSeek
API_KEY_DEEPSEEK=

# Mistral
API_KEY_MISTRAL=

# Groq
API_KEY_GROQ=

# xAI (Grok)
API_KEY_XAI=

# Perplexity
API_KEY_PERPLEXITY=
PERPLEXITY_API_KEY=
PERPLEXITY=

# Venice AI
API_KEY_VENICE=
API_KEY_AGIX_VENICE=
AGIX_VENICE=None
VENICE=

# SambaNova
API_KEY_SAMBANOVA=

# HuggingFace
API_KEY_HUGGINGFACE=

# AWS Bedrock
API_KEY_BEDROCK=

# GitHub Copilot
API_KEY_GITHUB_COPILOT=

# LM Studio (local)
API_KEY_LM_STUDIO=

# Ollama (local)
API_KEY_OLLAMA=

# CometAPI
API_KEY_COMETAPI=

# Other providers
API_KEY_OTHER=

# =============================================================================
# LLM PROVIDER SELECTION (set to model name or None to disable)
# =============================================================================
ANTHROPIC=None
COMETAPI=None
DEEPSEEK=None
GITHUB_COPILOT=None
GOOGLE=None
GROQ=None
LM_STUDIO=None
MISTRAL=None
OLLAMA=None
OPENAI=None
AZURE=None
SAMBANOVA=None
XAI=None
BEDROCK=None
OTHER=None
HUGGINGFACE=None
CONTEXT7=

# =============================================================================
# EXTERNAL SERVICE INTEGRATIONS
# =============================================================================
# GitHub
GITHUB_TOKEN=
GITHUB_PERSONAL_ACCESS_TOKEN=
# Automated GitHub user for loop prevention (default: your-bot-username)
GITHUB_WEBHOOK_USER=your-bot-username

# Forgejo (self-hosted Git)
FORGEJO_TOKEN=
FORGEJO_URL=

# Context7
CONTEXT7_API_KEY=

# Google Chat Integration
SECRET_GOOGLE_CHAT_CREDENTIALS=
SECRET_GOOGLE_CHAT_TOKEN=

# =============================================================================
# RAILWAY-SPECIFIC SETTINGS
# =============================================================================
# Railway automatically sets these, but you can override if needed:
# PORT=80
# RAILWAY_ENVIRONMENT=production
# RAILWAY_SERVICE_NAME=your-service-name

# =============================================================================
# DEVELOPMENT SETTINGS (ignored in production)
# =============================================================================
# AGIX_DEV_MODE and AGIX_ENV are set at the top of this file.
# In production (Railway), set AGIX_ENV=production and AGIX_DEV_MODE=false.
# To unlock all UI settings in production, set AGIX_DEV_MODE=true in Railway env vars.

# Cache buster for Docker builds
CACHE_DATE=none
